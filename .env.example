PORT=3000

# Firebase Admin SDK
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Colecciones Firestore
FIRESTORE_COLLECTION_USUARIOS=usuarios
FIRESTORE_COLLECTION_VERSION_CONTENIDO=version_contenido
FIRESTORE_COLLECTION_PAQUETE_CONTENIDO=paquete_contenido
FIRESTORE_COLLECTION_REGISTRO_DISPOSITIVOS=registro_dispositivos
FIRESTORE_COLLECTION_REGISTRO_SINCRONIZACIONES=registro_sincronizaciones
